# === Render/Docker 이미지에서 제외 (배포 필수 아님 or 비밀) ===

# git / CI
.git
.github
.gitattributes
.gitignore

# 파이썬 캐시
**/__pycache__/
*.pyc
.ipynb_checkpoints/
venv/

# 비밀키 — 배포는 환경변수(Render)로 주입, 이미지에 절대 굽지 않음
.env
.env.example
web/config.local.js
config.py

# 22MB 로컬 프론트 프로토타입 (gitignore 대상, 런타임 무관)
app/*.html

# 안 쓰는 벡터DB (서버는 chroma_smoke/cards 만 사용)
chroma_db/
chroma_seed_test/

# 런타임에 안 읽는 대용량 원본 (server 는 data/raw 에서 .jsonl 2개만 읽음)
data/raw/*.json
data/raw/*.tmp
data/rag/
data/mock/
data/golden/
data/share/

# 노트북 / 문서 / 로컬 전용 스크립트
notebooks/
design/
eval/
.streamlit/
run_local.bat
_*.py
_*.txt
*.md
07/
